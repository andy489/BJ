<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet author="stoevand" id="1">
        <createTable tableName="activation_tokens">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="created_at" type="datetime"/>
            <column name="token" type="VARCHAR(255)"/>
            <column name="user_id" type="BIGINT">
                <constraints unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="stoevand" id="2">
        <createTable tableName="credit_cards">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="card_cvc" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="card_holder" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="card_number" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="expired_month" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="expired_year" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="stoevand" id="3">
        <createTable tableName="last_games">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="hash" type="VARCHAR(31)"/>
            <column name="dealer_cards" type="VARCHAR(255)"/>
            <column name="player_cards" type="VARCHAR(255)"/>
            <column name="available_choices" type="VARCHAR(31)"/>
            <column name="taken_choices" type="VARCHAR(31)"/>
            <column name="win_multiplier" type="DOUBLE"/>
            <column name="finalized" type="BIT(1)"/>
            <column name="insurance" type="BIT(1)"/>
            <column name="second_dealer_card_ten" type="BIT(1)"/>
            <column name="err_code_list" type="VARCHAR(63)"/>
            <column name="owner_id" type="BIGINT">
                <constraints unique="true"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="stoevand" id="4">
        <createTable tableName="played_games">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="hash" type="VARCHAR(31)"/>
            <column name="dealer_cards" type="VARCHAR(255)"/>
            <column name="player_cards" type="VARCHAR(255)"/>
            <column name="taken_choices" type="VARCHAR(31)"/>
            <column name="win_multiplier" type="DOUBLE"/>
            <column name="insurance" type="BIT(1)"/>
            <column name="second_dealer_card_ten" type="BIT(1)"/>
            <column name="owner_id" type="BIGINT"/>
        </createTable>
    </changeSet>
    <changeSet author="stoevand" id="5">
        <createTable tableName="reset_pass_tokens">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="created_at" type="datetime"/>
            <column name="token" type="VARCHAR(255)"/>
            <column name="user_id" type="BIGINT">
                <constraints unique="true"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="stoevand" id="6">
        <createTable tableName="roles">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="role" type="ENUM('REGULAR', 'MODERATOR', 'ADMIN')">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="stoevand" id="7">
        <createTable tableName="users">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="birth_date" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="first_name" type="VARCHAR(255)"/>
            <column name="gender" type="ENUM('MALE', 'FEMALE', 'UNSPECIFIED')">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BIT(1)"/>
            <column name="last_name" type="VARCHAR(255)"/>
            <column name="password" type="VARCHAR(255)"/>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="my_wallet_id" type="BIGINT">
                <constraints unique="true"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="stoevand" id="8">
        <createTable tableName="users_roles">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="stoevand" id="9">
        <createTable tableName="wallets">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="balance" type="DECIMAL(38, 2)"/>
            <column name="current_bet" type="DECIMAL(38, 2)"/>
            <column name="last_bet" type="DECIMAL(38, 2)"/>
            <column name="last_win" type="DECIMAL(38, 2)"/>
            <column name="owner_id" type="BIGINT">
                <constraints unique="true"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="stoevand" id="10">
        <createIndex associatedWith="" indexName="FK2ycif7hrrfm42c8vbt5mhk6do" tableName="credit_cards">
            <column name="owner_id"/>
        </createIndex>
    </changeSet>
    <changeSet author="stoevand" id="11">
        <createIndex associatedWith="" indexName="FKbr4s7fht37juwsprroekga814" tableName="played_games">
            <column name="owner_id"/>
        </createIndex>
    </changeSet>
    <changeSet author="stoevand" id="12">
        <createIndex associatedWith="" indexName="FKj6m8fwv7oqv74fcehir1a9ffy" tableName="users_roles">
            <column name="role_id"/>
        </createIndex>
    </changeSet>
